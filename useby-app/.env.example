# UseBy local/deployment environment template.
# Do not put plaintext secrets in this file.

AWS_REGION=eu-west-2
AWS_ACCOUNT_ID=222634407676

# Aurora PostgreSQL via RDS Data API.
AURORA_DATABASE=useby
AURORA_CLUSTER_ARN=arn:aws:rds:eu-west-2:222634407676:cluster:h0-hackathon-aurora-pg
AURORA_SECRET_ARN=arn:aws:secretsmanager:eu-west-2:222634407676:secret:h0/useby/rds/app-user-YkF92c
# Backward-compatible alias supported by the runtime if already set in Vercel.
AURORA_APP_SECRET_ARN=

# Admin/migration secret. Use only for controlled migration/setup jobs.
AURORA_MASTER_SECRET_ARN=arn:aws:secretsmanager:eu-west-2:222634407676:secret:rds!cluster-355fac13-d836-4902-ad14-222ec537b2a3-KUfhwU

# S3 storage.
AWS_S3_BUCKET=h0-useby-assets-222634407676-eu-west-2

# Textract OCR uses AWS_REGION plus private S3 objects. No Textract API key is stored.
AWS_TEXTRACT_PROVIDER=textract

# Vercel OIDC. Set AWS_ROLE_ARN in Vercel after the scoped AWS role exists.
# Leave AWS_ROLE_ARN blank for local runs that use CloudShell or an AWS CLI profile.
AWS_ROLE_ARN=
VERCEL_TEAM_SLUG=abhinavs-projects-f1cef581
VERCEL_TEAM_ID=team_GIT6RlxBXVjXuY0g9nIeypsQ
VERCEL_PROJECT_ID=prj_QTVfZbuxGi6yISwdghbISaN10yz2

# Auth and product integrations will be filled in later checkpoints.
AUTH_SECRET=
AUTH_URL=http://localhost:3000
STRIPE_SECRET_KEY=
RESEND_API_KEY=
GEOCODING_PROVIDER=mapbox
MAPBOX_ACCESS_TOKEN=
